# Database connection string (Postgres). Use separate instances for dev vs production.
# Local dev: set your dev DB URL here or in .env.local (e.g. postgresql://localhost:5432/learning_platform_dev).
# Cursor Cloud: create a Neon branch via neonctl and set DATABASE_URL (see .cursor/rules/neon-branching.mdc; requires NEON_API_KEY).
# Production: set DATABASE_URL in Vercel (or your host) to the production DB URL.
DATABASE_URL=postgresql://127.0.0.1:5432/your-database-name

# Neon CLI auth for branching. Either:
# - Set NEON_API_KEY (required for Cursor Cloud; create at https://console.neon.tech → dev-payload → Settings → API keys), or
# - Run `pnpm exec neonctl auth` once locally (saves to ~/.config/neonctl/credentials.json). See https://neon.com/docs/reference/cli-auth
# NEON_API_KEY=your_key_here

# Used to encrypt JWT tokens. In production use a long random value: openssl rand -hex 32
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash. In production use https://yourdomain.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs (required if using jobs/cron)
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests (required for draft preview)
PREVIEW_SECRET=YOUR_PREVIEW_SECRET_HERE

# Optional: set to 1 when building for Docker to enable standalone output
# DOCKER_BUILD=1

# Better Auth: secret for session signing. Generate with: openssl rand -hex 32
BETTER_AUTH_SECRET=YOUR_BETTER_AUTH_SECRET_HERE

# Better Auth: base URL of the app (used for OAuth callbacks, etc.)
# On Vercel this is auto-derived from VERCEL_PROJECT_PRODUCTION_URL — only set for local dev or custom domains.
NEXT_PUBLIC_BETTER_AUTH_URL=http://localhost:3000

# Google OAuth: create credentials at https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Vercel Blob: Media uploads. Use separate stores for dev vs production (both must be Public).
# Production (Vercel): set BLOB_READ_WRITE_TOKEN to your production store token.
# Local dev: set BLOB_READ_WRITE_TOKEN_DEV to a dev store token (or use BLOB_READ_WRITE_TOKEN for a single store).
# BLOB_READ_WRITE_TOKEN=
# BLOB_READ_WRITE_TOKEN_DEV=
