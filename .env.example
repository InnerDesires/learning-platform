# Database connection string (Postgres for this project)
DATABASE_URL=postgresql://127.0.0.1:5432/your-database-name

# Used to encrypt JWT tokens. In production use a long random value: openssl rand -hex 32
PAYLOAD_SECRET=YOUR_SECRET_HERE

# Used to configure CORS, format links and more. No trailing slash. In production use https://yourdomain.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000

# Secret used to authenticate cron jobs (required if using jobs/cron)
CRON_SECRET=YOUR_CRON_SECRET_HERE

# Used to validate preview requests (required for draft preview)
PREVIEW_SECRET=YOUR_PREVIEW_SECRET_HERE

# Optional: set to 1 when building for Docker to enable standalone output
# DOCKER_BUILD=1

# Vercel only: from Vercel Blob storage so Media uploads persist. Leave unset for local dev.
# BLOB_READ_WRITE_TOKEN=
